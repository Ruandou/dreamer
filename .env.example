# Database
DATABASE_URL="postgresql://dreamer:dreamer123@localhost:5432/dreamer?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# MinIO / S3
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin123"
S3_BUCKET_VIDEOS="dreamer-videos"
S3_BUCKET_ASSETS="dreamer-assets"
S3_REGION="us-east-1"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ========== 文本模型 (LLM) ==========
LLM_DEFAULT_PROVIDER=deepseek

DEEPSEEK_API_KEY="your-deepseek-api-key"
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
DEEPSEEK_DEFAULT_MODEL="deepseek-v4-flash"

OPENAI_API_KEY="your-openai-api-key"
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_DEFAULT_MODEL="gpt-4o"

ARK_LLM_API_KEY="your-ark-llm-api-key"
ARK_LLM_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
ARK_LLM_DEFAULT_MODEL="doubao-pro-32k-241215"

# ========== 图片模型 (Image) ==========
IMAGE_DEFAULT_PROVIDER=ark

ARK_IMAGE_API_KEY="your-ark-image-api-key"
ARK_IMAGE_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
ARK_IMAGE_T2I_MODEL="doubao-seedream-5-0-lite-260128"
ARK_IMAGE_EDIT_MODEL="doubao-seedream-5-0-lite-260128"
ARK_IMAGE_EDIT_USE_BASE64=1
# ARK_IMAGE_YUAN_PER_MILLION_TOKENS=4

KLING_IMAGE_API_KEY="your-kling-image-api-key"
KLING_IMAGE_BASE_URL="https://api-beijing.klingai.com"
KLING_IMAGE_T2I_MODEL="kling-image-o1"

OPENAI_IMAGE_API_KEY="your-openai-image-api-key"
OPENAI_IMAGE_BASE_URL="https://api.openai.com/v1"
OPENAI_IMAGE_T2I_MODEL="dall-e-3"

# ========== 视频模型 (Video) ==========
VIDEO_DEFAULT_PROVIDER=ark

ARK_VIDEO_API_KEY="your-ark-video-api-key"
ARK_VIDEO_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
ARK_VIDEO_MODEL="doubao-seedance-2-0-fast-260128"

KLING_VIDEO_API_KEY="your-kling-video-api-key"
KLING_VIDEO_BASE_URL="https://api-beijing.klingai.com"
KLING_VIDEO_MODEL="kling-video-o1"

# ========== 联网搜索 (Search) ==========
SEARCH_DEFAULT_PROVIDER=volc

VOLC_SEARCH_API_KEY="your-volc-search-api-key"
VOLC_SEARCH_BASE_URL="https://open.feedcoopapi.com"

# ========== 兼容旧配置 ==========
# 以下配置仍被支持，但建议迁移到上方的新格式
# ARK_API_KEY（兼容 ARK_IMAGE_API_KEY / ARK_VIDEO_API_KEY）
# ARK_API_URL（兼容 ARK_IMAGE_BASE_URL / ARK_VIDEO_BASE_URL）

# Atlas Cloud API (Wan 2.6)
ATLAS_API_KEY="your-atlas-api-key"
ATLAS_API_URL="https://api.atlascloud.com"

# FFmpeg (optional, for video composition)
FFMPEG_PATH="/usr/local/bin/ffmpeg"
