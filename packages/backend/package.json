{
  "name": "@dreamer/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "prisma generate && tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "prisma generate && tsc",
    "start": "node --import ./dist/bootstrap-env.js dist/index.js",
    "start:worker": "node --import ./dist/bootstrap-env.js dist/worker.js",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "node -e \"require('dotenv').config({path:'../../.env'}); process.exit(require('child_process').spawnSync('prisma', ['migrate', 'deploy'], {stdio:'inherit', env:process.env}).status)\"",
    "db:migrate:squash-drift-rows": "node -e \"require('dotenv').config({path:'../../.env'}); process.exit(require('child_process').spawnSync('pnpm', ['exec', 'prisma', 'db', 'execute', '--file', 'prisma/squash-drop-old-migration-rows.sql'], {stdio:'inherit', env: process.env}).status)\"",
    "db:push": "node -e \"require('dotenv').config({path:'../../.env'}); process.exit(require('child_process').spawnSync('prisma', ['db', 'push'], {stdio:'inherit', env:process.env}).status)\"",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "postinstall": "prisma generate",
    "test": "NODE_OPTIONS='--max-old-space-size=8192' vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dreamer/shared": "workspace:*",
    "@aws-sdk/client-s3": "^3.525.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.0",
    "@fastify/multipart": "^8.1.0",
    "@fastify/static": "^7.0.1",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@prisma/client": "^5.11.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.4.0",
    "fastify": "^4.26.2",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.3.2",
    "openai": "^4.29.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^1.6.0",
    "dotenv": "^16.4.0",
    "prisma": "^5.11.0",
    "tsx": "^4.7.1",
    "typescript": "^5.4.0",
    "vitest": "1.6.0"
  }
}
