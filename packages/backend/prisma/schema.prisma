generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  apiKey    String?
  deepseekApiUrl String?
  // 其他 API Keys
  atlasApiKey    String?
  atlasApiUrl    String?
  arkApiKey      String?
  arkApiUrl      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[]
  apiCalls ModelApiCall[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  episodes     Episode[]
  characters   Character[]
  compositions Composition[]
  importTasks  ImportTask[]

  @@index([userId])
}

model Episode {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  episodeNum Int
  title      String?
  script     Json?    // 存储结构化剧本JSON
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  scenes Scene[]

  @@unique([projectId, episodeNum])
  @@index([projectId])
}

model Character {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  images      CharacterImage[]

  @@index([projectId])
}

model CharacterImage {
  id          String   @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  name        String
  avatarUrl   String?
  parentId    String?   // 父节点 ID，null 表示基础形象
  type        String    @default("base")  // base/outfit/expression/pose
  description String?
  order       Int      @default(0)       // 排序
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent      CharacterImage? @relation("ImageHierarchy", fields: [parentId], references: [id])
  children    CharacterImage[] @relation("ImageHierarchy")

  @@index([characterId])
  @@index([parentId])
}

model Scene {
  id          String   @id @default(cuid())
  episodeId   String
  episode     Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  sceneNum    Int
  description String?
  prompt      String
  status      String   @default("pending") // pending/processing/completed/failed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks VideoTask[]

  @@unique([episodeId, sceneNum])
  @@index([episodeId])
}

model VideoTask {
  id              String   @id @default(cuid())
  sceneId         String
  scene           Scene    @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  model           String
  externalTaskId  String?  // 外部 API (火山引擎/Atlas) 的任务 ID
  status          String   @default("queued") // queued/processing/completed/failed
  prompt          String
  cost            Float?
  duration        Int?     // 生成耗时（秒）
  videoUrl        String?
  thumbnailUrl    String?
  errorMsg        String?
  isSelected      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([sceneId])
  @@index([externalTaskId])
  apiCalls ModelApiCall[]
}

model ModelApiCall {
  id              String   @id @default(cuid())
  userId         String
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 模型信息
  model          String   // wan2.6, seedance2.0, deepseek, etc.
  provider       String   // volcengine, atlas, openai, deepseek

  // 请求信息
  prompt         String
  requestParams  String?  // JSON: { imageUrls, duration, quality, referenceImage, etc. }

  // 响应信息
  externalTaskId String?  // 外部 API 的任务 ID
  status         String   @default("pending") // pending/processing/completed/failed
  responseData   String?  // JSON: { videoUrl, thumbnailUrl, etc. }

  // 费用和时间
  cost           Float?
  duration       Int?     // 生成耗时（秒）

  // 错误信息
  errorMsg       String?

  // 关联任务（可选）
  videoTaskId    String?
  videoTask      VideoTask? @relation(fields: [videoTaskId], references: [id], onDelete: SetNull)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([externalTaskId])
  @@index([model])
  @@index([createdAt])
}

model Composition {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title      String
  duration   Int      @default(0)
  width      Int      @default(1080)
  height     Int      @default(1920)
  status     String   @default("draft") // draft/composing/exporting/exported
  voiceover  String?
  bgm        String?
  subtitles  String?
  outputUrl  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  segments Segment[]

  @@index([projectId])
}

model Segment {
  id            String      @id @default(cuid())
  compositionId String
  composition   Composition @relation(fields: [compositionId], references: [id], onDelete: Cascade)
  sceneId       String
  order         Int
  startTime     Float
  endTime       Float
  transition    String?

  @@index([compositionId])
}

model ImportTask {
  id          String   @id @default(cuid())
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId      String
  status      String   @default("pending") // pending/processing/completed/failed
  content     String
  type        String   @default("markdown")
  result      Json?
  errorMsg    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}
