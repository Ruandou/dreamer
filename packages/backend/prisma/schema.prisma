generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  apiKey    String?
  deepseekApiUrl String?
  // 其他 API Keys
  atlasApiKey    String?
  atlasApiUrl    String?
  arkApiKey      String?
  arkApiUrl      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[]
  apiCalls ModelApiCall[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  visualStyle String[] @default([]) // 视频风格: realistic, cinematic, vintage
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  episodes      Episode[]
  characters    Character[]
  locations     Location[]
  compositions Composition[]
  importTasks  ImportTask[]
  pipelineJobs  PipelineJob[]
  assets       ProjectAsset[]

  @@index([userId])
}

model Episode {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  episodeNum Int
  title      String?
  synopsis   String?  // 分集摘要
  script     Json?    // 存储结构化剧本JSON
  sceneIndices Int[] @default([]) // 场景索引列表
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  segments Segment[]

  @@unique([projectId, episodeNum])
  @@index([projectId])
}

model Character {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  images      CharacterImage[]

  @@unique([projectId, name])
  @@index([projectId])
}

model CharacterImage {
  id          String   @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  name        String
  avatarUrl   String?
  parentId    String?   // 父节点 ID，null 表示基础形象
  type        String    @default("base")  // base/outfit/expression/pose
  description String?
  order       Int      @default(0)       // 排序
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent      CharacterImage? @relation("ImageHierarchy", fields: [parentId], references: [id])
  children    CharacterImage[] @relation("ImageHierarchy")
  segmentUsages CharacterSegment[]

  @@index([characterId])
  @@index([parentId])
}

// Segment - 分镜片段（视频生成单元）
model Segment {
  id              String   @id @default(cuid())
  episodeId       String
  episode        Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  segmentNum     Int      // 分镜序号
  description    String?  // 分镜描述
  locationId      String?
  location       Location? @relation(fields: [locationId], references: [id])
  duration       Int?     // 总时长(毫秒)
  cameraMovement String?  // 运镜方式
  aspectRatio    String?  // 9:16 / 16:9 / 1:1
  prompt         String   // 视频生成提示词
  visualStyle    String[] @default([]) // 视觉风格
  status        String   @default("pending") // pending/generating/completed/failed
  seedanceParams Json?   // Seedance API 参数
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tasks              VideoTask[]
  characterSegments  CharacterSegment[]
  subShots          SubShot[]

  @@unique([episodeId, segmentNum])
  @@index([episodeId])
  @@index([locationId])
}

// SubShot - 子片段（时序描述）
model SubShot {
  id           String   @id @default(cuid())
  segmentId    String
  segment     Segment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  order       Int      // 顺序
  durationMs   Int      // 时长(毫秒)
  description  String   // 描述文本
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([segmentId])
}

// CharacterSegment - 片段中的人物及其造型
model CharacterSegment {
  id               String   @id @default(cuid())
  segmentId        String
  segment         Segment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  characterImageId String   // 该片段中使用的人物具体形象
  characterImage   CharacterImage @relation(fields: [characterImageId], references: [id])
  action          String?  // 该片段中角色的动作/情绪
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([segmentId, characterImageId])
  @@index([segmentId])
  @@index([characterImageId])
}

// Location - 场地（从剧本提取）
model Location {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  location    String   // 地点名称
  timeOfDay   String?  // 日/夜/晨/昏
  characters  String[] @default([]) // 出场角色列表
  description String?  // 场景描述
  imageUrl    String?  // 场地图片 URL（AI 生成）
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  segments Segment[]

  @@unique([projectId, location])
  @@index([projectId])
}

model VideoTask {
  id              String   @id @default(cuid())
  segmentId        String
  segment         Segment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  model           String
  externalTaskId  String?  // 外部 API (火山引擎/Atlas) 的任务 ID
  status          String   @default("queued") // queued/processing/completed/failed
  prompt          String
  cost            Float?
  duration        Int?     // 生成耗时（秒）
  videoUrl        String?
  thumbnailUrl    String?
  errorMsg        String?
  isSelected      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([segmentId])
  @@index([externalTaskId])
  apiCalls ModelApiCall[]
}

model ModelApiCall {
  id              String   @id @default(cuid())
  userId         String
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 模型信息
  model          String   // wan2.6, seedance2.0, deepseek, etc.
  provider       String   // volcengine, atlas, openai, deepseek

  // 请求信息
  prompt         String
  requestParams  String?  // JSON: { imageUrls, duration, quality, referenceImage, etc. }

  // 响应信息
  externalTaskId String?  // 外部 API 的任务 ID
  status         String   @default("pending") // pending/processing/completed/failed
  responseData   String?  // JSON: { videoUrl, thumbnailUrl, etc. }

  // 费用和时间
  cost           Float?
  duration       Int?     // 生成耗时（秒）

  // 错误信息
  errorMsg       String?

  // 关联任务（可选）
  videoTaskId    String?
  videoTask      VideoTask? @relation(fields: [videoTaskId], references: [id], onDelete: SetNull)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([externalTaskId])
  @@index([model])
  @@index([createdAt])
}

model Composition {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title      String
  duration   Int      @default(0)
  width      Int      @default(1080)
  height     Int      @default(1920)
  status     String   @default("draft") // draft/composing/exporting/exported
  voiceover  String?
  bgm        String?
  subtitles  String?
  outputUrl  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  segments CompositionSegment[]

  @@index([projectId])
}

model CompositionSegment {
  id            String      @id @default(cuid())
  compositionId String
  composition   Composition @relation(fields: [compositionId], references: [id], onDelete: Cascade)
  segmentId      String      // 引用 Pipeline Segment
  order         Int
  startTime     Float
  endTime       Float
  transition    String?

  @@index([compositionId])
}

model ImportTask {
  id          String   @id @default(cuid())
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId      String
  status      String   @default("pending") // pending/processing/completed/failed
  content     String
  type        String   @default("markdown")
  result      Json?
  errorMsg    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// PipelineJob - Pipeline 执行任务
model PipelineJob {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status      String   @default("pending") // pending/running/completed/failed
  currentStep String   @default("script-writing") // script-writing/episode-split/segment-extract/storyboard
  progress    Int      @default(0)         // 0-100
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stepResults PipelineStepResult[]

  @@index([projectId])
}

// PipelineStepResult - Pipeline 各步骤的详细结果
model PipelineStepResult {
  id          String   @id @default(cuid())
  jobId       String
  job         PipelineJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  step        String   // script-writing/episode-split/segment-extract/storyboard
  status      String   @default("pending") // pending/processing/completed/failed
  input       Json?    // 步骤输入数据
  output      Json?    // 步骤输出数据
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([jobId, step])
  @@index([jobId])
}

// OutlineJob - 大纲生成异步任务
model OutlineJob {
  id        String   @id @default(cuid())
  userId    String
  status    String   @default("pending") // pending/running/completed/failed
  idea      String   // 用户输入的想法
  result    Json?    // 生成结果（outline + rawScript）
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model ProjectAsset {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type        String   // character/background/atmosphere/prop/style
  name        String
  url         String
  description String?
  tags        String[] // JSON array
  mood        String[] // JSON array
  location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
}
