generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  password       String
  apiKey         String?
  deepseekApiUrl String?
  atlasApiKey    String?
  atlasApiUrl    String?
  arkApiKey      String?
  arkApiUrl      String?
  /// 用户模型偏好配置 { llm?: { provider, model }, image?: { provider, model }, video?: { provider, model }, search?: { provider } }
  modelPreferences Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  projects Project[]
  apiCalls ModelApiCall[]
  scripts  Script[]
  chatConversations ChatConversation[]
}

model Project {
  id           String   @id @default(cuid())
  name         String
  description  String?
  synopsis     String?
  storyContext String?  @db.Text
  /// 项目画幅（文生图尺寸、新建场次、导入等；如 9:16、16:9、1:1、4:3、3:4、21:9）
  aspectRatio String?
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  visualStyle  String[] @default([])
  /// 结构化视觉风格配置（4 维度：时代 + 艺术 + 色调 + 画质）
  visualStyleConfig Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  episodes     Episode[]
  characters   Character[]
  locations    Location[]
  compositions Composition[]
  importTasks  ImportTask[]
  pipelineJobs PipelineJob[]
  assets       ProjectAsset[]
  memories     MemoryItem[]
  memorySnapshots MemorySnapshot[]

  @@index([userId])
}

model Episode {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  episodeNum Int
  title      String?
  synopsis   String?
  script     Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  scenes       Scene[]
  compositions Composition[]
  memories     MemoryItem[]

  @@unique([projectId, episodeNum])
  @@index([projectId])
}

model Character {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String?
  voiceId     String?
  voiceConfig Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  images    CharacterImage[]
  dialogues SceneDialogue[] @relation("CharacterDialogues")

  @@unique([projectId, name])
  @@index([projectId])
}

model CharacterImage {
  id            String   @id @default(cuid())
  characterId String
  character     Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  name          String
  prompt        String?
  avatarUrl     String?
  imageCost     Float? // 方舟图片最近一次成功：估算成本（元），见 image-generation
  parentId      String?
  type          String   @default("base")
  description   String?
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  parent           CharacterImage? @relation("ImageHierarchy", fields: [parentId], references: [id])
  children         CharacterImage[] @relation("ImageHierarchy")
  characterShots   CharacterShot[]

  @@index([characterId])
  @@index([parentId])
}

model Scene {
  id             String   @id @default(cuid())
  episodeId      String
  episode        Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  sceneNum       Int
  locationId     String?
  location       Location? @relation(fields: [locationId], references: [id])
  timeOfDay      String?
  description    String   @default("")
  duration       Int      @default(0)
  aspectRatio    String   @default("9:16")
  visualStyle    String[] @default([])
  seedanceParams Json?
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  shots             Shot[]
  dialogues         SceneDialogue[] @relation("SceneDialogues")
  takes             Take[]
  compositionUsages CompositionScene[]

  @@unique([episodeId, sceneNum])
  @@index([episodeId])
  @@index([locationId])
}

model Shot {
  id             String   @id @default(cuid())
  sceneId        String
  scene          Scene    @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  shotNum        Int
  order          Int
  description    String
  duration       Int      @default(0)
  cameraMovement String?
  cameraAngle    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  characterShots CharacterShot[]

  @@index([sceneId])
}

model CharacterShot {
  id                 String   @id @default(cuid())
  shotId             String
  shot               Shot     @relation(fields: [shotId], references: [id], onDelete: Cascade)
  characterImageId   String
  characterImage     CharacterImage @relation(fields: [characterImageId], references: [id])
  action             String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([shotId, characterImageId])
  @@index([shotId])
  @@index([characterImageId])
}

model SceneDialogue {
  id          String   @id @default(cuid())
  sceneId     String
  scene       Scene    @relation("SceneDialogues", fields: [sceneId], references: [id], onDelete: Cascade)
  characterId String
  character   Character @relation("CharacterDialogues", fields: [characterId], references: [id])
  order       Int
  startTimeMs Int
  durationMs  Int
  text        String
  voiceConfig Json
  emotion     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sceneId, startTimeMs])
  @@index([characterId])
}

model Location {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String   @map("location")
  timeOfDay   String?
  characters  String[] @default([])
  description String?
  imagePrompt String?
  imageUrl    String?
  imageCost   Float? // 定场图最近一次成功：估算成本（元）
  deletedAt   DateTime? // 软删除：列表不展示，费用统计仍计入该行
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  scenes Scene[]

  @@unique([projectId, name])
  @@index([projectId])
  @@index([projectId, deletedAt])
}

model Take {
  id             String   @id @default(cuid())
  sceneId        String
  scene          Scene    @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  model          String
  externalTaskId String?
  status         String   @default("queued")
  prompt         String
  cost           Float?
  duration       Int?
  videoUrl       String?
  thumbnailUrl   String?
  errorMsg       String?
  isSelected     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  apiCalls            ModelApiCall[]
  compositionUsages   CompositionScene[]

  @@index([sceneId])
  @@index([externalTaskId])
}

model ModelApiCall {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  model          String
  provider       String
  prompt         String
  requestParams  String?
  externalTaskId String?
  status         String   @default("pending")
  responseData   String?
  cost           Float?
  duration       Int?
  errorMsg       String?
  takeId         String?
  take           Take?    @relation(fields: [takeId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([externalTaskId])
  @@index([model])
  @@index([createdAt])
}

model Composition {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  episodeId  String
  episode    Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  title      String
  status     String   @default("draft")
  outputUrl  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  scenes CompositionScene[]

  @@index([projectId])
  @@index([episodeId])
}

model CompositionScene {
  id              String      @id @default(cuid())
  compositionId   String
  composition     Composition @relation(fields: [compositionId], references: [id], onDelete: Cascade)
  sceneId         String
  scene           Scene       @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  takeId          String
  take            Take        @relation(fields: [takeId], references: [id], onDelete: Cascade)
  order           Int

  @@index([compositionId])
  @@index([sceneId])
  @@index([takeId])
}

model ImportTask {
  id          String   @id @default(cuid())
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId      String
  status      String   @default("pending")
  content     String
  type        String   @default("markdown")
  result      Json?
  errorMsg    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model PipelineJob {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status       String   @default("pending")
  jobType      String   @default("full-pipeline")
  currentStep  String   @default("script-writing")
  progress     Int      @default(0)
  progressMeta Json?
  error        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  stepResults PipelineStepResult[]

  @@index([projectId])
}

model PipelineStepResult {
  id        String      @id @default(cuid())
  jobId     String
  job       PipelineJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  step      String
  status    String      @default("pending")
  input     Json?
  output    Json?
  error     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([jobId, step])
  @@index([jobId])
}

model ProjectAsset {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type        String
  name        String
  url         String
  description String?
  tags        String[]
  mood        String[]
  location    String?
  source      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
}

// 剧情记忆系统
enum MemoryType {
  CHARACTER
  LOCATION
  EVENT
  PLOT_POINT
  FORESHADOWING
  RELATIONSHIP
  VISUAL_STYLE
}

model MemoryItem {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // 分类
  type        MemoryType
  category    String?  // 细分：major_character, minor_location, etc.

  // 内容
  title       String   // 简短标题
  content     String   @db.Text  // 详细描述
  metadata    Json?    // 结构化数据：{ episodeNum, characters, location, importance }

  // 向量检索（后续扩展）
  embedding   Float[]  @default([])

  // 关联
  relatedIds  String[] @default([])
  episodeId   String?
  episode     Episode? @relation(fields: [episodeId], references: [id])

  // 管理
  tags        String[] @default([])
  importance  Int      @default(3)  // 1-5，5最重要
  isActive    Boolean  @default(true)
  verified    Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId, type])
  @@index([projectId, isActive])
  @@index([projectId, importance])
  @@index([projectId, episodeId, type])
  @@index([episodeId])
}

model MemorySnapshot {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  snapshotAt  DateTime @default(now())
  upToEpisode Int

  summary     String   @db.Text
  contextJson Json

  createdAt   DateTime @default(now())

  @@unique([projectId, upToEpisode])
  @@index([projectId])
}

// AI 写作工作室剧本（独立于 Episode，暂时关联 User，后续可扩展关联 Project）
enum ScriptStatus {
  DRAFT     // 草稿，编辑中
  READY     // 定稿，可用于解析骨架和生成视频
  ARCHIVED  // 已归档
}

model Script {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 未来可扩展：关联到 Project（从 Script 立项）
  projectId   String?
  // project   Project?     @relation(fields: [projectId], references: [id])

  title       String       @default("未命名剧本")
  content     String       @db.Text   // 剧本全文，纯文本
  status      ScriptStatus @default(DRAFT)
  tags        String[]     @default([])

  // 版本预留（暂不启用版本表）
  version     Int          @default(1)

  // Agent 相关字段
  targetEpisode     Int?               // 目标集数
  generationStatus  Json?              // { step, outline, draft, memories }

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  chatConversations ChatConversation[]
  memories          ScriptMemoryItem[]

  @@index([userId])
  @@index([status])
}

// AI 编剧助手对话
model ChatConversation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scriptId  String?
  script    Script?  @relation(fields: [scriptId], references: [id], onDelete: SetNull)
  title     String   @default("新对话")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  ChatMessage[]

  @@index([userId])
  @@index([scriptId])
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String           // 'user' | 'assistant' | 'system'
  content        String           @db.Text
  status         String           @default("completed") // 'completed' | 'streaming' | 'failed'
  inputTokens    Int?
  outputTokens   Int?
  costCNY        Float?
  metadata       Json?            // { quickCommand?, suggestedEdit?, model? }
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([conversationId])
  @@index([conversationId, createdAt])
}

// 剧本独立记忆（草稿阶段使用，定稿后可同步到项目记忆）
model ScriptMemoryItem {
  id          String       @id @default(cuid())
  scriptId    String
  script      Script       @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  // 分类（与 MemorySystem 对齐）
  type        MemoryType
  category    String?      // 细分：major_character, minor_location 等

  // 内容
  title       String       // 简短标题
  content     String       @db.Text  // 详细描述
  metadata    Json?        // { episodeNum, characters, location, importance }

  // 管理
  tags        String[]     @default([])
  importance  Int          @default(3)  // 1-5
  isActive    Boolean      @default(true)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([scriptId, type])
  @@index([scriptId, isActive])
}

// Agent 检查点（用于状态持久化和故障恢复）
model AgentCheckpoint {
  id        String   @id @default(cuid())
  scriptId  String
  agentType String   // "outline", "draft", "critic", "revision"
  phase     String   // "generating", "reviewing", "revising"
  state     Json     // Serialized agent state
  version   Int      @default(1)
  createdAt DateTime @default(now())

  @@index([scriptId])
  @@index([agentType])
}
