# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
packages/*/dist/

# Environment files - NEVER COMMIT THESE
.env
.env.local
.env.*.local
# Exception: allow .env.example for documentation
!.env.example

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Prisma：`prisma/migrations/` 必须纳入版本管理，勿加入 .gitignore

# MinIO data
docker/data/

# Temporary files
*.tmp
*.temp

# TypeScript cache
*.tsbuildinfo

# Auto-generated types
packages/frontend/src/auto-imports.d.ts
packages/frontend/src/components.d.ts

# Test coverage
packages/*/coverage/

# Credentials and secrets (if accidentally committed)
*.pem
*.key
credentials.json
secrets.json
