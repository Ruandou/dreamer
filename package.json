{
  "name": "dreamer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI短剧工作台 - 从剧本到成品的全流程AI短剧生产平台",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:backend": "pnpm --filter @dreamer/backend run dev",
    "dev:worker": "pnpm --filter @dreamer/backend run dev:worker",
    "dev:frontend": "pnpm --filter @dreamer/frontend run dev",
    "build": "pnpm --filter @dreamer/shared run build && pnpm --filter @dreamer/backend run build && pnpm --filter @dreamer/frontend run build",
    "db:generate": "pnpm --filter @dreamer/backend run db:generate",
    "db:push": "pnpm --filter @dreamer/backend run db:push",
    "docker:up": "cd docker && docker compose up -d",
    "docker:down": "cd docker && docker compose down",
    "start": "pnpm --filter @dreamer/backend run start",
    "test": "pnpm --filter @dreamer/backend exec vitest run && pnpm --filter @dreamer/frontend test",
    "lint": "eslint 'packages/**/*.{ts,js}'",
    "lint:fix": "eslint 'packages/**/*.{ts,js}' --fix",
    "format": "prettier --write 'packages/**/*.{ts,js,json,md}'",
    "format:check": "prettier --check 'packages/**/*.{ts,js,json,md}'",
    "knip": "knip",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "knip": "^6.4.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^5.4.0"
  },
  "lint-staged": {
    "packages/backend/**/*.{ts,js}": [
      "prettier --write",
      "pnpm --filter @dreamer/backend test -- related --run"
    ],
    "packages/frontend/**/*.{ts,vue}": [
      "prettier --write",
      "pnpm --filter @dreamer/frontend test -- related --run"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.15.5+sha512.845196026aab1cc3f098a0474b64dfbab2afe7a1b4e91dd86895d8e4aa32a7a6d03049e2d0ad770bbe4de023a7122fb68c1a1d6e0d033c7076085f9d5d4800d4"
}
