#!/bin/sh
cd /Users/leifu/Learn/dreamer

# 获取变更的文件
CHANGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# 检查各包是否有变更
BACKEND_CHANGED=false
FRONTEND_CHANGED=false

if echo "$CHANGED_FILES" | grep -q "^packages/backend/"; then
  BACKEND_CHANGED=true
fi

if echo "$CHANGED_FILES" | grep -q "^packages/frontend/"; then
  FRONTEND_CHANGED=true
fi

# 如果后端代码有变更，运行后端测试
if [ "$BACKEND_CHANGED" = true ]; then
  echo "🔬 后端代码变更，运行测试..."
  cd packages/backend && pnpm test --run
  if [ $? -ne 0 ]; then
    echo "❌ 后端测试失败，提交被阻止"
    exit 1
  fi
  echo "✅ 后端测试通过"
fi

# 如果前端代码有变更，运行前端测试
if [ "$FRONTEND_CHANGED" = true ]; then
  echo "🔬 前端代码变更，检查测试..."
  if [ -f "packages/frontend/vitest.config.ts" ] || [ -f "packages/frontend/vite.config.ts" ]; then
    cd packages/frontend && pnpm test --run 2>/dev/null
    if [ $? -ne 0 ]; then
      echo "❌ 前端测试失败，提交被阻止"
      exit 1
    fi
    echo "✅ 前端测试通过"
  else
    echo "⚠️ 前端无测试配置，跳过"
  fi
fi

# 如果没有任何变更的文件
if [ "$BACKEND_CHANGED" = false ] && [ "$FRONTEND_CHANGED" = false ]; then
  echo "ℹ️  没有代码变更，跳过测试"
fi

echo "✅ 提交完成"
